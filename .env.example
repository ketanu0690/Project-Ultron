# Copy to .env at the repo root before running:
#   cp .env.example .env
#   docker compose --env-file .env -f infra/docker-compose.yml up --build
#
# Do not commit .env — it is gitignored.

# PostgreSQL
POSTGRES_USER=ultron
POSTGRES_DB=ultron
DB_PASSWORD=change-me-local-dev

# Redis (internal Docker hostname)
REDIS_URL=redis://redis:6379
# MinIO object storage
MINIO_ROOT_USER=ultron-minio
MINIO_ROOT_PASSWORD=change-me-local-dev
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=ultron-minio
MINIO_SECRET_KEY=change-me-local-dev

# Grafana admin login
GRAFANA_ADMIN_PASSWORD=change-me-local-dev

# Web (browser-facing — use localhost when ports are published to host)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# AI providers (optional for health-only boot)
OPENROUTER_API_KEY=

# Local LLM fallback — set when using: docker compose --env-file .env -f infra/docker-compose.yml --profile ollama up
OLLAMA_BASE_URL=http://ollama:11434
